# Copy this file to `.env` and fill in real values. Do NOT commit your real .env.
#
#   cp .env.example .env      (Windows: copy .env.example .env)

# Database. PostgreSQL is preferred; if the connection fails the app falls back to
# a local SQLite file (backend/cdrdb.sqlite3) with no extra configuration.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cdrdb

# Application
APP_NAME=CDR/IPDR Investigation Visualizer

# Auth / sessions
AUTH_SESSION_COOKIE_NAME=gpcssi_session
AUTH_SESSION_TTL_HOURS=168

# Default admin created on first startup if no admin exists.
# CHANGE THESE before deploying anywhere — the password must be at least 8 chars.
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change-this-password
AUTH_BOOTSTRAP_ROLE=admin

# Optional: path to an external ASN/CIDR CSV (network,provider,is_isp) to extend
# service attribution coverage (e.g. exported from MaxMind GeoLite2-ASN / IPinfo).
# ASN_RANGES_CSV=data/asn_ranges.csv
